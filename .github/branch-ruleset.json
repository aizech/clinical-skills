{
  "name": "Clinical Skills Branch Protection",
  "target": "branch",
  "enforcement": "active",
  "conditions": {
    "ref_name": {
      "include": [
        "refs/heads/main",
        "refs/heads/master"
      ],
      "exclude": []
    }
  },
  "rules": [
    {
      "type": "deletion",
      "parameters": {
        "force_push": false
      }
    },
    {
      "type": "non_fast_forward",
      "parameters": {
        "allow_deletions": false,
        "allow_force_pushes": false
      }
    },
    {
      "type": "pull_request",
      "parameters": {
        "dismiss_stale_reviews_on_push": true,
        "require_code_owner_review": true,
        "required_approving_review_count": 1,
        "require_last_push_approval": true,
        "required_review_thread_resolution": true
      }
    },
    {
      "type": "required_status_checks",
      "parameters": {
        "required_status_checks": [
          {
            "context": "Security Baseline Check / security-baseline",
            "integration_id": null
          },
          {
            "context": "Security Baseline Check / report",
            "integration_id": null
          },
          {
            "context": "Validate Skill",
            "integration_id": null
          },
          {
            "context": "Sync Skills",
            "integration_id": null
          }
        ],
        "strict_required_status_checks_policy": true
      }
    },
    {
      "type": "update",
      "parameters": {
        "allowed_user_roles": [
          "admin"
        ],
        "allowed_team_ids": [],
        "allowed_apps": [],
        "allowed_actor_ids": [],
        "allow_fork_syncing": false,
        "always_require_pr": true
      }
    }
  ],
  "bypass_actor_ids": []
}